{
  "name": "family-manager",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:all": "bash scripts/test-all.sh",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @family-manager/api start:dev",
    "dev:worker": "pnpm --filter @family-manager/worker start:dev",
    "dev:openclaw-adapter": "pnpm --filter @family-manager/openclaw-adapter start:dev",
    "dev:telegram-codex": "pnpm --filter @family-manager/telegram-codex start:dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
