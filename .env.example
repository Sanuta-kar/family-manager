NODE_ENV=development
PUBLIC_API_BASE_URL=https://family.example.com
# In production the API refuses to boot if DATABASE_URL still uses the default
# family:family credentials, or if JWT_SECRET is unset/short/left at the dev default.
DATABASE_URL=postgresql://family:family@postgres:5432/family_manager?schema=public
REDIS_URL=redis://redis:6379
# Must be a long, random, non-default value in production (>= 16 chars).
JWT_SECRET=replace-with-a-long-random-secret
FCM_SERVICE_ACCOUNT_JSON=
OPENCLAW_ADAPTER_URL=http://openclaw-adapter:4010
OPENCLAW_BASE_URL=http://openclaw:8080
PROOF_STORAGE_PATH=/var/lib/family-manager/proofs

# Optional Telegram -> Codex bridge.
# Create a bot with BotFather, send it a message, then read your chat id from:
# https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CODEX_MAX_PROMPT_CHARS=6000
TELEGRAM_CODEX_RUN_TIMEOUT_MS=1200000
TELEGRAM_CODEX_SESSION_FILE=/srv/fm/family-manager/.telegram-codex-sessions.json
CODEX_BIN=codex
CODEX_WORKDIR=/srv/fm/family-manager
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=never
CODEX_EXTRA_ARGS=
